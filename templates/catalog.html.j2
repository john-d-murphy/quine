{% extends "base.html.j2" %}
{% block title %}Tag Catalog{% endblock %}
{% block content %}
<div class="catalog-layout">

  <header class="catalog-header">
    <h1>Tag Catalog</h1>
    <p class="catalog-meta">
      {{ total_tags }} tag{% if total_tags != 1 %}s{% endif %}
      · {{ total_refs }} reference{% if total_refs != 1 %}s{% endif %}
      {% if total_drifted %} · <span class="drift-count">{{ total_drifted }} drifted</span>{% endif %}
    </p>
  </header>

  {% if orphans %}
  <section class="drift-section">
    <h2>Drifted References</h2>
    <p class="drift-note">These directives reference tags that no longer exist in source.</p>
    <ul class="drift-list">
      {% for o in orphans %}
      <li><code>{{ o.name }}</code> <span class="drift-source">in {{ o.label }}</span></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% for repo_id, repo_tags in by_repo.items() %}
  <section class="repo-section">
    <h2 class="repo-heading">{{ repo_id }}</h2>
    <ul class="tag-list">
      {% for tag in repo_tags %}
      <li class="tag-item">
        <div class="tag-header">
          <code class="tag-name">{{ tag.name }}</code>
          <span class="tag-file">{{ tag.source_file }}</span>
          {% if tag.language %}<span class="tag-lang">{{ tag.language }}</span>{% endif %}
        </div>
        {% if tag.prose %}<p class="tag-prose">{{ tag.prose }}</p>{% endif %}
        {% if tag.refs %}
        <ul class="tag-refs">
          {% for ref in tag.refs %}
          <li class="tag-ref {% if ref.drifted %}tag-ref--drifted{% endif %}">
            {{ ref.label }}{% if ref.drifted %} <span class="drift-badge">drifted</span>{% endif %}
          </li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="tag-no-refs">no prose references yet</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endfor %}

</div>
{% endblock %}
