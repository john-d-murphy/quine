<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ page.title | default('') }}{% endblock %} — {{ site.title | default('quine') }}</title>
  {% if page.canonical %}<link rel="canonical" href="{{ page.canonical }}">{% endif %}
  <link rel="stylesheet" href="{{ base_href }}assets/site.css">
  <link rel="stylesheet" href="{{ base_href }}assets/code.css">
</head>
<body>
  <nav class="site-nav">
    <a href="{{ base_href }}" class="nav-home">{{ site.title | default('quine') }}</a>
    <a href="{{ base_href }}tags/" class="nav-link">tags</a>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
